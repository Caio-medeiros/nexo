{
  "name": "nexo-tests",
  "version": "1.0.0",
  "private": true,
  "description": "NEXO platform test suite (unit + config scan + Playwright E2E). No build step — the site is static.",
  "type": "module",
  "scripts": {
    "dev": "node tests/perf/gzserve.mjs . 8888",
    "test:unit": "node tests/unit/run.mjs",
    "test:coverage": "c8 --include=js/nexo-security.js --check-coverage --lines 90 --statements 90 --branches 75 --functions 95 --reporter=text --reporter=html --report-dir=tests/coverage node tests/unit/run.mjs",
    "test:scan": "node tests/scan/scan.mjs",
    "test:rls": "node tests/rls/rls.mjs",
    "test": "npm run test:coverage && npm run test:scan",
    "test:e2e": "playwright test -c tests/e2e/playwright.config.js",
    "perf:serve": "node tests/perf/gzserve.mjs . 8891",
    "perf:ci": "lhci autorun --config=.lighthouserc.json"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.48.0",
    "c8": "^11.0.0",
    "lighthouse": "^12.8.2"
  }
}
