# Node deps (test harness) — lockfile IS committed (CI uses `npm ci`)
node_modules/

# Supabase CLI local temp
supabase/.temp/

# Stray export
--full-page

# Secrets — never commit. Service-role / Anthropic / VAPID keys live only as
# Supabase secrets, never in client-side files.
.env
.env.*
*.env


# Graphify knowledge-graph artefacts (local only)
graphify-out/

# Coverage output (gerado por npm run test:coverage)
tests/coverage/
coverage/

# Playwright — artefactos e relatórios gerados (npm run test:e2e)
test-results/
tests/playwright-report/

# Lighthouse CI — relatórios locais (gerados por npm run perf:ci)
.lighthouseci/
tests/perf/lhci-report/
